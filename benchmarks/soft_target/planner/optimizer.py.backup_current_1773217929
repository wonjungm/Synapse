import time

def monitor_and_replan():
    """
    Monitor GPU performance and trigger REPLAN or DEGRADE based on slowdown conditions.
    """
    sustained_time = {gpu_id: 0 for gpu_id in alpha_g.keys()}  # Track sustained slowdown time
    replan_time = {gpu_id: 0 for gpu_id in alpha_g.keys()}    # Track REPLAN time
    degrade_time = {gpu_id: 0 for gpu_id in alpha_g.keys()}   # Track DEGRADE time

    while True:
        for gpu_id in alpha_g.keys():
            # Simulate stage time monitoring (replace with actual monitoring logic)
            stage_time = get_snet_stage_time(0, snet_num_layers - 1, gpu_id)  # Example for SNet
            stage_time_base = 1.0  # Replace with actual baseline time

            # Calculate slowdown
            slowdown = calculate_slowdown(stage_time, stage_time_base, ema_slowdown=1.0)  # Replace EMA logic

            # State transitions
            if slowdown < 1.1:
                sustained_time[gpu_id] = 0
                replan_time[gpu_id] = 0
                degrade_time[gpu_id] = 0
                logging.info(f"GPU {gpu_id} in KEEP state.")

            elif slowdown >= 1.1:
                sustained_time[gpu_id] += 1
                if sustained_time[gpu_id] >= 30:
                    logging.info(f"GPU {gpu_id} triggered REPLAN due to sustained slowdown.")
                    replan_optimizer("tnet.csv", "snet.csv", slowdown)
                    replan_time[gpu_id] = 0
                    degrade_time[gpu_id] = 0

            elif slowdown >= 1.25:
                replan_time[gpu_id] += 1
                if replan_time[gpu_id] >= 60:
                    logging.warning(f"GPU {gpu_id} triggered DEGRADE due to prolonged slowdown after REPLAN.")
                    degrade_time[gpu_id] = 0

        time.sleep(1)  # Monitor every second

# Start monitoring and replan
if __name__ == "__main__":
    monitor_and_replan()