def get_snet_stage_time(layer_i, layer_j, gpu_id, alpha_g_override=None, beta_g_override=None):
    """Calculate SNet stage time with optional slowdown correction factors.
    
    Args:
        alpha_g_override: compute slowdown factors dict (overrides global alpha_g)
        beta_g_override: communication slowdown factors dict (overrides global beta_g)
    """
    fwd_time = np.sum(snet_forward_times_ms[layer_i:layer_j+1]) * 1e-3  # ms -> s
    bwd_time = np.sum(snet_backward_times_ms[layer_i:layer_j+1]) * 1e-3  # ms -> s

    last_layer = snet_num_layers - 1
    recv_act_time = 0
    recv_grad_time = 0

    if layer_i != 0:
        recv_act_size = snet_input_activation_sizes_kb[layer_i]
        recv_act_time = recv_act_size / bandwidth_kbps  # time to receive activations in seconds
    if layer_j != last_layer:
        recv_grad_size = snet_output_activation_sizes_kb[layer_j]
        recv_grad_time = recv_grad_size / bandwidth_kbps  # time to receive gradients in seconds

    # GPU별 alpha_g와 beta_g 적용 (override 있으면 사용, 없으면 전역값)
    use_alpha_g = alpha_g_override if alpha_g_override is not None else alpha_g
    use_beta_g = beta_g_override if beta_g_override is not None else beta_g
    
    alpha_val = use_alpha_g.get(gpu_id, 1.0) if isinstance(use_alpha_g, dict) else use_alpha_g
    beta_val = use_beta_g.get(gpu_id, 1.0) if isinstance(use_beta_g, dict) else use_beta_g
    
    snet_total_time = beta_val * (recv_act_time + recv_grad_time) + alpha_val * (fwd_time + bwd_time)
    return snet_total_time

def get_tnet_stage_time(layer_i, layer_j, gpu_id, alpha_g_override=None, beta_g_override=None):
    """Calculate TNet stage time with optional slowdown correction factors.
    
    Args:
        alpha_g_override: compute slowdown factors dict (overrides global alpha_g)
        beta_g_override: communication slowdown factors dict (overrides global beta_g)
    """
    fwd_time = np.sum(tnet_forward_times_ms[layer_i:layer_j+1]) * 1e-3  # ms -> s
    recv_act_time = 0

    if layer_i != 0:
        recv_act_size = tnet_input_activation_sizes_kb[layer_i]
        recv_act_time = recv_act_size / bandwidth_kbps  # time to receive activations in seconds

    # GPU별 alpha_g와 beta_g 적용 (override 있으면 사용, 없으면 전역값)
    use_alpha_g = alpha_g_override if alpha_g_override is not None else alpha_g
    use_beta_g = beta_g_override if beta_g_override is not None else beta_g
    
    alpha_val = use_alpha_g.get(gpu_id, 1.0) if isinstance(use_alpha_g, dict) else use_alpha_g
    beta_val = use_beta_g.get(gpu_id, 1.0) if isinstance(use_beta_g, dict) else use_beta_g
    
    tnet_total_time = beta_val * recv_act_time + alpha_val * fwd_time
    return tnet_total_time

def calculate_ema(current_value, previous_ema, alpha=0.1):
    return alpha * current_value + (1 - alpha) * previous_ema

def calculate_slowdown(stage_time, stage_time_base, ema_slowdown):
    ema_slowdown = calculate_ema(stage_time, ema_slowdown)
    return ema_slowdown / stage_time_base

def determine_state(slowdown, sustained_time, replan_time, degrade_time):
    if slowdown < 1.1:
        return "KEEP"
    elif slowdown >= 1.1 and sustained_time >= 30:
        return "REPLAN"
    elif slowdown >= 1.25 and replan_time >= 60:
        return "DEGRADE"
    else:
        return "KEEP"

def make_equal_split(num_layers, num_stages):
    """Create equal layer split across stages."""
    base = num_layers // num_stages
    rem = num_layers % num_stages
    return [base + (1 if i < rem else 0) for i in range(num_stages)]

def imbalance_ratio(partition_lengths, get_stage_time):
    """Calculate worst-to-mean time ratio for given partition."""
    times = []
    start = 0
    for length in partition_lengths:
        end = start + length - 1         # inclusive index
        times.append(get_stage_time(start, end))
        start = end + 1

    worst  = max(times)
    mean   = sum(times) / len(times)
    ratio  = worst / mean if mean > 0 else float('inf')
    return ratio, times

def reconstruct_partition(partition_table, num_layers, num_stages):
    """Reconstruct layer partition from DP backtracking table."""
    lengths = []
    curr_layer = num_layers
    for s in reversed(range(1, num_stages + 1)):
        prev_layer = partition_table[curr_layer][s]
        lengths.append(curr_layer - prev_layer)
        curr_layer = prev_layer
    return list(reversed(lengths))

def compute_optimal_partition(num_stages, alpha_g_override=None, beta_g_override=None):
    """Compute optimal layer partition using DP with optional slowdown correction.
    
    This function runs the DP algorithm to find the best layer-to-stage assignment.
    Can be called with override values (from replan_optimizer) or defaults (global alpha/beta).
    
    Args:
        num_stages: Number of pipeline stages
        alpha_g_override: Compute slowdown factors {gpu_id: factor} (e.g., {0:1.3, 1:1.0})
        beta_g_override: Communication slowdown factors {gpu_id: factor}
    
    Returns:
        (snet_split, tnet_split, snet_imbalance, tnet_imbalance, snet_times, tnet_times)
    """
    logging.info(f"[COMPUTE_PARTITION] Starting DP with alpha={alpha_g_override}, beta={beta_g_override}")
    
    # Initialize DP tables (local)
    snet_dp = np.full((snet_num_layers + 1, num_stages + 1), np.inf)
    tnet_dp = np.full((tnet_num_layers + 1, num_stages + 1), np.inf)
    snet_partition = np.full((snet_num_layers + 1, num_stages + 1), -1)
    tnet_partition = np.full((tnet_num_layers + 1, num_stages + 1), -1)

    snet_dp[0][0] = 0
    tnet_dp[0][0] = 0

    # Run DP for SNet
    t0 = time.perf_counter()
    for i in range(1, snet_num_layers + 1):
        for s in range(1, num_stages + 1):
            for j in range(s - 1, i):
                snet_time = get_snet_stage_time(j, i - 1, 0, alpha_g_override, beta_g_override)
                candidate = max(snet_dp[j][s - 1], snet_time)
                if candidate < snet_dp[i][s]:
                    snet_dp[i][s] = candidate
                    snet_partition[i][s] = j

    # Run DP for TNet
    for i in range(1, tnet_num_layers + 1):
        for s in range(1, num_stages + 1):
            for j in range(s - 1, i):
                tnet_time = get_tnet_stage_time(j, i - 1, 0, alpha_g_override, beta_g_override)
                candidate = max(tnet_dp[j][s - 1], tnet_time)
                if candidate < tnet_dp[i][s]:
                    tnet_dp[i][s] = candidate
                    tnet_partition[i][s] = j
    
    dp_duration = (time.perf_counter() - t0) * 1000
    logging.info(f"[COMPUTE_PARTITION] DP completed in {dp_duration:.3f} ms")

    # Reconstruct partitions
    snet_split = reconstruct_partition(snet_partition, snet_num_layers, num_stages)
    tnet_split = reconstruct_partition(tnet_partition, tnet_num_layers, num_stages)

    # Calculate imbalance ratios
    snet_imbalance, snet_times = imbalance_ratio(
        snet_split,
        lambda i, j: get_snet_stage_time(i, j, 0, alpha_g_override, beta_g_override)
    )
    tnet_imbalance, tnet_times = imbalance_ratio(
        tnet_split,
        lambda i, j: get_tnet_stage_time(i, j, 0, alpha_g_override, beta_g_override)
    )
    
    return snet_split, tnet_split, snet_imbalance, tnet_imbalance, snet_times, tnet_times

def replan_optimizer(tnet_csv, snet_csv, slowdown, avail_mem=None):
    """Replan optimizer with slowdown correction factors.
    
    This is called during failover when GPU performance degradation is detected.
    It recomputes the optimal partition using the observed slowdown factor.
    
    Args:
        tnet_csv: Path to tnet profile CSV (currently unused, data already loaded)
        snet_csv: Path to snet profile CSV (currently unused, data already loaded)
        slowdown: Observed slowdown factor (e.g., 1.3 means 30% slower)
        avail_mem: Available memory (currently unused)
    
    Returns:
        dict with 'snet_split', 'tnet_split', imbalance ratios
    """
    logging.info(f"\n[REPLAN] Starting replan with slowdown factor={slowdown}")
    
    # Convert slowdown factor to alpha/beta correction
    # Assumption: slowdown is applied to compute (alpha)
    # All GPUs get same correction for simplicity (can be per-GPU in future)
    corrected_alpha = {gpu_id: slowdown for gpu_id in alpha_g.keys()}
    corrected_beta = {gpu_id: 1.0 for gpu_id in beta_g.keys()}  # Communication unchanged
    
    logging.info(f"[REPLAN] Applying alpha correction: {corrected_alpha}")
    
    # Compute new optimal partition with corrected factors
    snet_split_new, tnet_split_new, snet_imb, tnet_imb, snet_times, tnet_times = \
        compute_optimal_partition(num_stages, corrected_alpha, corrected_beta)
    
    # Log results
    logging.info(f"[REPLAN] OLD partition: snet={snet_split}, tnet={tnet_split}")
    logging.info(f"[REPLAN] NEW partition: snet={snet_split_new}, tnet={tnet_split_new}")
    logging.info(f"[REPLAN] Imbalance ratios: snet={snet_imb:.3f}, tnet={tnet_imb:.3f}")
    logging.info(f"[REPLAN] Stage times (s): snet={[f'{t:.3f}' for t in snet_times]}, tnet={[f'{t:.3f}' for t in tnet_times]}")
    
    return {
        'snet_split': snet_split_new,
        'tnet_split': tnet_split_new,
        'snet_imbalance': snet_imb,
        'tnet_imbalance': tnet_imb,
        'snet_stage_times': snet_times,
        'tnet_stage_times': tnet_times,
    }


